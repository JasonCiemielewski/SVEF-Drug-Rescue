# Environments
.svef/
.venv/
env/
venv/

# Python
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/

# Jupyter
.ipynb_checkpoints/

# Data (Ignore all except demo data)
data/raw/*
data/raw_first/
data/interim/*
data/processed/*
!data/processed/SVEF_Enriched_Final.csv
!data/demo/
!data/interim/audit/svef_logic_audit.csv
!data/interim/master_ml_df_enriched.csv

# Cache and temporary files
nonexistent_cache.csv

# Reports, Notebooks & Docs
# Keep the directory but ignore generated assets
docs/*_files/
docs/*.html

# Share figures in reports/figures/
# Do not share archived figures or notebook figures
notebooks/*.png
reports/figures/archived/*
!reports/figures/archived/.gitkeep

# Ignore notebooks by default, then whitelist specific ones
notebooks/*.ipynb
!notebooks/Midterm_Presentation.ipynb
notebooks/svef_dataset_creation.ipynb
!notebooks/Random_Forest_Analysis.ipynb
!notebooks/EDA_AACT.ipynb

# Ignore src by default, then whitelist specific ones
src/data/*.py
src/features/*.py
src/pipeline/*.py
!src/data/clean_drug_name.py
!src/v4_arm_cleaner.py
!src/features/cleaning.py
!src/features/enrichment.py


# Ignore tests by default, then whitelist specific ones
tests/*.py
!test_cleaning.py
!test_enrichment.py
!test_v4_arm_cleaner.py

# Office/Temp files
*.xlsx
*.pdf
~$*
script_*.py
